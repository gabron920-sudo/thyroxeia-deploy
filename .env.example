# ══════════════════════════════════════════════════════════════════════════════
#  Thyroxeia AI Backend — Environment Variables
#  Copy this to .env for local dev. In Railway: paste each into Variables tab.
# ══════════════════════════════════════════════════════════════════════════════

# ── Gemini AI Key Pool (up to 5 keys — backend auto-rotates when one hits quota)
# Get free keys at: aistudio.google.com/app/apikey
# ✅ REQUIRED — at least GEMINI_API_KEY must be set
GEMINI_API_KEY=your_gemini_key_1_here
GEMINI_API_KEY_2=your_gemini_key_2_here
GEMINI_API_KEY_3=your_gemini_key_3_here
GEMINI_API_KEY_4=your_gemini_key_4_here
GEMINI_API_KEY_5=your_gemini_key_5_here

# ── PayPal (live credentials from developer.paypal.com → your app)
# ✅ REQUIRED for payments
PAYPAL_CLIENT_ID=Acn3s6SAOb8iSxAwv_hxXBgPRIiWOrgTXuAoRCyN58xxhcr59N2d43DJpI77lIxsQ_jIc7er_uYGCs0W
PAYPAL_CLIENT_SECRET=your_paypal_live_client_secret_here
PAYPAL_MODE=live
# Set PAYPAL_MODE=sandbox for testing with sandbox.paypal.com

# ── Supabase
# ✅ REQUIRED for plan activation and AI usage tracking
SUPABASE_URL=https://jxmajkyfbznmcixsghjz.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp4bWFqa3lmYnpubWNpeHNnaGp6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYwNjcyODUsImV4cCI6MjA5MTY0MzI4NX0.zMDLa6EvpDCErgOCx4Ur8QSxOMdn-1ikXvaL1QSRHGs
# ⚠️  Service Role key — NEVER put this in frontend. Supabase → Settings → API → service_role
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── SMTP (branded emails — OTP, welcome, elite welcome)
# Gmail App Password: Google Account → Security → 2-Step Verification → App passwords
# ✅ REQUIRED for email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=Thyroxeia AI <your_gmail@gmail.com>

# ── Server
PORT=3001
# Your Netlify frontend URL — used for CORS (no trailing slash)
FRONTEND_URL=https://your-site.netlify.app
